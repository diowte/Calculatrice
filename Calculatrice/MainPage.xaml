<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Calculatrice.MainPage"
    BackgroundColor="#000000"
    Padding="14">

    <Grid RowDefinitions="Auto,*" RowSpacing="12">

        <!-- Écran -->
        <Label x:Name="Display"
               Grid.Row="0"
               Text="0"
               TextColor="White"
               FontSize="52"
               HorizontalTextAlignment="End"
               VerticalTextAlignment="Center"
               HeightRequest="110" />

        <Grid Grid.Row="1"
              VerticalOptions="End"
              RowSpacing="10"
              ColumnSpacing="10">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Ligne 1 -->
            <Button Text="AC" Grid.Row="0" Grid.Column="0" Clicked="OnClear"
                    BackgroundColor="#A5A5A5" TextColor="Black"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="1/x" Grid.Row="0" Grid.Column="1" Clicked="OnInverse"
                    BackgroundColor="#A5A5A5" TextColor="Black"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="%" Grid.Row="0" Grid.Column="2" Clicked="OnPercent"
                    BackgroundColor="#A5A5A5" TextColor="Black"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="÷" Grid.Row="0" Grid.Column="3" Clicked="OnOperator"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>

            <!-- Ligne 2 -->
            <Button Text="7" Grid.Row="1" Grid.Column="0" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="8" Grid.Row="1" Grid.Column="1" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="9" Grid.Row="1" Grid.Column="2" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="×" Grid.Row="1" Grid.Column="3" Clicked="OnOperator"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>

            <!-- Ligne 3 -->
            <Button Text="4" Grid.Row="2" Grid.Column="0" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="5" Grid.Row="2" Grid.Column="1" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="6" Grid.Row="2" Grid.Column="2" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="−" Grid.Row="2" Grid.Column="3" Clicked="OnOperator"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>

            <!-- Ligne 4 -->
            <Button Text="1" Grid.Row="3" Grid.Column="0" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="2" Grid.Row="3" Grid.Column="1" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="3" Grid.Row="3" Grid.Column="2" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="+" Grid.Row="3" Grid.Column="3" Clicked="OnOperator"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>

            <!-- Ligne 5 -->
            <Button Text="±" Grid.Row="4" Grid.Column="0" Clicked="OnSign"
                    BackgroundColor="#A5A5A5" TextColor="Black"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="0" Grid.Row="4" Grid.Column="1" Clicked="OnNumber"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="." Grid.Row="4" Grid.Column="2" Clicked="OnDecimal"
                    BackgroundColor="#333333" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
            <Button Text="=" Grid.Row="4" Grid.Column="3" Clicked="OnEqual"
                    BackgroundColor="#FF9F0A" TextColor="White"
                    CornerRadius="100" HeightRequest="70" FontSize="28"/>
        </Grid>
    </Grid>
</ContentPage>
